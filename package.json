{
  "name": "@puzige/acp-router",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.10.3",
  "description": "Generic MCP server for routing coding tasks to local ACP agents. Works with any MCP client (Claude Desktop, Cursor, Windsurf, Codex, etc.).",
  "license": "MIT",
  "author": {
    "name": "puzige"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puzige/acp-router.git"
  },
  "keywords": [
    "mcp",
    "acp",
    "agent",
    "router",
    "coding-agents",
    "model-context-protocol"
  ],
  "type": "module",
  "bin": {
    "acp-router": "dist/bin/acp-router.js",
    "acp-router-cli": "dist/bin/acp-router-cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsgo && chmod +x dist/bin/acp-router.js dist/bin/acp-router-cli.js",
    "check": "tsgo --noEmit",
    "start": "node ./dist/bin/acp-router.js",
    "start:mcp": "node ./dist/server.js",
    "prepublishOnly": "tsgo && chmod +x dist/bin/acp-router.js dist/bin/acp-router-cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
